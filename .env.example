DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psc_jobs
PDF_STORAGE_PATH=data/pdfs
MAX_NOTIFICATIONS=10
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ISSUER=notification-scrapper
JWT_AUDIENCE=notification-scrapper-users
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
PASSWORD_RESET_TTL_MINUTES=30
LOGIN_RATE_LIMIT_PER_MINUTE=5
FORGOT_RATE_LIMIT_PER_HOUR=5
